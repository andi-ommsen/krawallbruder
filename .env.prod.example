# Kopieren: cp .env.prod.example .env.prod  (NICHT ins Git einchecken!)

# Symfony
APP_ENV=prod
APP_SECRET=<langen_zufaelligen_string_generieren>
APP_BASE_URL=https://deine-domain.de
CORS_ALLOW_ORIGIN=https://deine-domain.de

# Datenbank (PostgreSQL im Docker-Netzwerk)
DATABASE_URL="postgresql://kb_user:SICHERES_PASSWORT@database:5432/krawallbruder?serverVersion=16&charset=utf8"

# PostgreSQL Container-Variablen (müssen mit DATABASE_URL übereinstimmen)
POSTGRES_DB=krawallbruder
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=

# Frontend Build-Arg (wird beim docker-compose build übergeben)
VITE_API_URL=https://deine-domain.de


git pull origin master

VITE_API_URL=https://krawallbruder.de \
docker compose --env-file .env.prod -f docker-compose.prod.yml build --no-cache

docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --remove-orphans
scp deploy@176.103.221.219:/home/deploy/krawallbruder/backend/migrations/Version20260308091357.php "C:\Users\jensw\claudecode\krawallbruder\backend\migrations\"
