frontend/.env.local
frontend/.env*.local

# Backend-Secrets
backend/.env.local
backend/.env.prod
.env.prod

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
